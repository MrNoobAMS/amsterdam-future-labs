---

<svg
  class:list={['feature-icon', className]}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d={d} />
</svg>

<style>
  .feature-icon {
    width: 1.5rem;
    height: 1.5rem;
  }
</style>
