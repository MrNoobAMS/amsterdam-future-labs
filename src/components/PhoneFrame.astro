---
/**
 * iPhone-style device frame around a screenshot. Screenshots are lazily
 * loaded by default; pass eager for above-the-fold heroes.
 *
 * Pass `framed` for screenshots that already are branded, captioned App
 * Store images (their own background + caption): these are shown flat with
 * rounded corners and a soft shadow, without the device bezel/notch.
 */
interface Props {
  src: string;
  alt: string;
  eager?: boolean;
  framed?: boolean;
  class?: string;
}

const { src, alt, eager = false, framed = false, class: className = '' } = Astro.props;

// Serve AVIF/WebP siblings for raster (PNG) screenshots; SVG placeholders
// render as-is. The .avif/.webp files are produced by generate-assets.mjs.
const isRaster = /\.png$/i.test(src);
const avif = isRaster ? src.replace(/\.png$/i, '.avif') : null;
const webp = isRaster ? src.replace(/\.png$/i, '.webp') : null;
---

{framed ? (
  <figure class:list={['shot', className]}>
    <picture>
      {avif && <source srcset={avif} type="image/avif" />}
      {webp && <source srcset={webp} type="image/webp" />}
      <img
        src={src}
        alt={alt}
        width="330"
        height="717"
        loading={eager ? 'eager' : 'lazy'}
        fetchpriority={eager ? 'high' : 'auto'}
        decoding="async"
      />
    </picture>
  </figure>
) : (
  <figure class:list={['phone', className]}>
    <div class="phone-body">
      <span class="phone-notch" aria-hidden="true"></span>
      <picture>
        {avif && <source srcset={avif} type="image/avif" />}
        {webp && <source srcset={webp} type="image/webp" />}
        <img
          src={src}
          alt={alt}
          width="330"
          height="717"
          loading={eager ? 'eager' : 'lazy'}
          fetchpriority={eager ? 'high' : 'auto'}
          decoding="async"
        />
      </picture>
    </div>
  </figure>
)}

<style>
  .phone {
    margin: 0;
    width: clamp(200px, 100%, 300px);
  }

  /* Flat, pre-branded App Store screenshot (no device bezel). */
  .shot {
    margin: 0;
    width: clamp(200px, 100%, 300px);
  }

  .shot img {
    width: 100%;
    height: auto;
    aspect-ratio: 1320 / 2868;
    object-fit: contain;
    border-radius: clamp(1.1rem, 6cqw, 1.6rem);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06),
      0 24px 60px -20px rgba(0, 0, 0, 0.5);
  }

  .phone-body {
    position: relative;
    border-radius: clamp(2rem, 12cqw, 2.9rem);
    padding: clamp(0.4rem, 2.2cqw, 0.55rem);
    background: linear-gradient(160deg, #3a3d46, #15161b 40%, #2c2f38);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.09),
      0 24px 60px -20px rgba(0, 0, 0, 0.55),
      inset 0 1px 1px rgba(255, 255, 255, 0.12);
    container-type: inline-size;
  }

  .phone-notch {
    position: absolute;
    top: clamp(0.7rem, 3.5cqw, 0.95rem);
    left: 50%;
    transform: translateX(-50%);
    width: 26%;
    height: clamp(0.55rem, 3cqw, 0.75rem);
    border-radius: 999px;
    background: #060709;
    z-index: 2;
  }

  .phone-body img {
    width: 100%;
    height: auto;
    aspect-ratio: 1320 / 2868;
    object-fit: cover;
    border-radius: clamp(1.6rem, 10cqw, 2.4rem);
    background: #0d0e12;
  }
</style>
