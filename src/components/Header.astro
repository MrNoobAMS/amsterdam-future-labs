---
const links = [
  { href: '/', label: 'Home' },
  { href: '/apps/', label: 'Apps' },
  { href: '/work/', label: 'Work with us' },
  { href: '/privacy/', label: 'Privacy' },
  { href: '/faq/', label: 'FAQ' },
  { href: '/support/', label: 'Support' },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Amsterdam Future Labs — home">
      <span class="brand-mark" aria-hidden="true">
        <svg class="brand-logo" viewBox="0 0 64 64" role="img">
          <defs>
            <linearGradient id="brandGrad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#6366f1" />
              <stop offset="0.5" stop-color="#8b5cf6" />
              <stop offset="1" stop-color="#22d3ee" />
            </linearGradient>
          </defs>
          <rect width="64" height="64" rx="16" fill="url(#brandGrad)" />
          <path
            class="brand-logo-a"
            d="M18 44 L32 18 L46 44"
            fill="none"
            stroke="#fff"
            stroke-width="5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <circle class="brand-logo-dot" cx="32" cy="38" r="3.5" fill="#fff" />
        </svg>
      </span>
      <span class="brand-name">Amsterdam<br />Future Labs</span>
    </a>

    <nav class="nav-desktop" aria-label="Main">
      {links.map((l) => (
        <a href={l.href} class:list={['nav-link', { 'is-active': isActive(l.href) }]}>
          {l.label}
        </a>
      ))}
    </nav>

    <button
      class="menu-toggle"
      id="menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <span class="menu-line"></span>
      <span class="menu-line"></span>
    </button>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <nav class="mobile-nav on-dark" aria-label="Mobile">
    {links.map((l, i) => (
      <a
        href={l.href}
        class:list={['mobile-link', { 'is-active': isActive(l.href) }]}
        style={`--i:${i}`}
      >
        {l.label}
      </a>
    ))}
    <p class="mobile-menu-footer" style={`--i:${links.length}`}>
      support@amsterdamfuturelabs.com
    </p>
  </nav>
</div>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    transition: background-color 0.35s var(--ease-out), box-shadow 0.35s var(--ease-out);
  }

  /* Filled state once the page is scrolled (toggled from BaseLayout script) */
  .site-header.is-scrolled {
    background: rgba(11, 12, 16, 0.72);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    backdrop-filter: blur(18px) saturate(1.4);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.07);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.25rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--text-light);
  }

  /* --- Animated brand mark (the favicon logo) ---
     Driven by --logo-p (0 at the top → 1 once scrolled away), set on the
     header from BaseLayout's scroll handler. */
  .brand-mark {
    width: 1.9rem;
    height: 1.9rem;
    flex-shrink: 0;
    transform-origin: center;
  }

  @media (prefers-reduced-motion: no-preference) {
    .brand-mark {
      /* Larger + a touch of lift at the very top, shrinking back as you scroll. */
      transform: scale(calc(1.16 - var(--logo-p, 0) * 0.16))
        translateY(calc(var(--logo-p, 0) * 0.5px));
    }
  }

  .brand-logo {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 0.6rem;
    /* Glow eases off as the filled header background fades in. */
    filter: drop-shadow(
      0 6px 16px rgba(99, 102, 241, calc(0.55 - var(--logo-p, 0) * 0.3))
    );
    transition: filter 0.35s var(--ease-out);
  }

  /* One-time "draw the A" intro on load. */
  @media (prefers-reduced-motion: no-preference) {
    .brand-logo-a {
      stroke-dasharray: 60;
      stroke-dashoffset: 60;
      animation: brand-draw 0.9s 0.15s var(--ease-out) forwards;
    }

    .brand-logo-dot {
      transform-origin: 32px 38px;
      transform: scale(0);
      animation: brand-pop 0.45s 0.85s var(--ease-out) forwards;
    }
  }

  @keyframes brand-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes brand-pop {
    from {
      transform: scale(0);
    }
    60% {
      transform: scale(1.35);
    }
    to {
      transform: scale(1);
    }
  }

  .brand-name {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .nav-desktop {
    display: none;
    gap: 0.35rem;
  }

  .nav-link {
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 550;
    color: var(--text-light-secondary);
    text-decoration: none;
    transition: color 0.25s var(--ease-out), background-color 0.25s var(--ease-out);
  }

  .nav-link:hover {
    color: var(--text-light);
    background: rgba(255, 255, 255, 0.08);
  }

  .nav-link.is-active {
    color: var(--text-light);
    background: rgba(255, 255, 255, 0.1);
  }

  /* --- Hamburger --- */
  .menu-toggle {
    display: grid;
    place-content: center;
    gap: 5px;
    width: 2.75rem;
    height: 2.75rem;
    margin-right: -0.5rem;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .menu-line {
    width: 1.35rem;
    height: 2px;
    border-radius: 2px;
    background: var(--text-light);
    transition: transform 0.35s var(--ease-out);
  }

  .menu-toggle[aria-expanded='true'] .menu-line:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }

  .menu-toggle[aria-expanded='true'] .menu-line:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  /* --- Mobile overlay --- */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 90;
    background: rgba(11, 12, 16, 0.96);
    -webkit-backdrop-filter: blur(24px);
    backdrop-filter: blur(24px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s var(--ease-out), visibility 0s linear 0.4s;
  }

  .mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.4s var(--ease-out);
  }

  .mobile-nav {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
    padding: 0 2rem;
  }

  .mobile-link {
    font-size: clamp(2rem, 8vw, 2.8rem);
    font-weight: 650;
    letter-spacing: var(--tracking-tight);
    color: var(--text-light);
    text-decoration: none;
    padding: 0.35rem 0;
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 0.5s var(--ease-out),
      transform 0.5s var(--ease-out),
      color 0.25s var(--ease-out);
  }

  .mobile-menu.is-open .mobile-link,
  .mobile-menu.is-open .mobile-menu-footer {
    opacity: 1;
    transform: none;
    transition-delay: calc(0.06s + var(--i) * 0.055s);
  }

  .mobile-link:hover,
  .mobile-link.is-active {
    color: var(--brand-c);
  }

  .mobile-menu-footer {
    margin-top: 2.2rem;
    font-size: 0.85rem;
    color: var(--text-light-secondary);
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out);
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
    .menu-toggle,
    .mobile-menu {
      display: none;
    }
  }
</style>
