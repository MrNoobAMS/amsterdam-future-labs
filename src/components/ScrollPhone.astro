---
/**
 * 3D scroll experience (ORYZO-style): a WebGL iPhone that translates down and
 * rotates as you scroll. Each time the screen faces the camera it shows the
 * next app from the portfolio; the texture is swapped while the screen faces
 * away, so the change is hidden.
 *
 * Progressive enhancement: the panels below hold real text content and a
 * static fallback image, so the section is meaningful without WebGL (no-JS or
 * prefers-reduced-motion). The Three.js scene renders into the sticky canvas.
 */
import { SUPPORT_EMAIL } from '../data/apps';

// Faces shown on the rotating phone, in scroll order. `screen` textures are
// generated by scripts/generate-scroll-textures.mjs. Panel 0 is the studio
// welcome; the rest are featured apps.
const panels = [
  {
    screen: '/images/three/screen-company.jpg',
    eyebrow: 'Independent app studio · Amsterdam',
    title: 'Apps you’ll love to use — and trust.',
    body: 'Amsterdam Future Labs designs premium iPhone apps for cooking, calm and play. Private by design, offline first, crafted to the last detail. Scroll to meet them.',
  },
  {
    screen: '/images/three/screen-meal-planner.jpg',
    eyebrow: 'Meal Planner',
    title: 'Plan smarter. Eat better.',
    body: 'A week planner, calorie and protein tracking, and a shopping list that builds itself — all on your device.',
    href: '/apps/meal-planner/',
  },
  {
    screen: '/images/three/screen-breathwell.jpg',
    eyebrow: 'BreathWell',
    title: 'Breathe better. Feel better.',
    body: 'Guided breathing sessions with a calm, tactile player and progress you actually keep — no account, ever.',
    href: '/apps/breathwell/',
  },
  {
    screen: '/images/three/screen-kamado-companion.jpg',
    eyebrow: 'Kamado Companion',
    title: 'Master fire. Create flavor.',
    body: 'Recipes, a temperature guide for 35+ cuts, and a BBQ planner that counts back from serving time.',
    href: '/apps/kamado-companion/',
  },
  {
    screen: '/images/three/screen-sudoku-xl.jpg',
    eyebrow: 'Sudoku XL',
    title: 'Pure sudoku, beautifully made.',
    body: 'A beautiful board, smart hints that teach real techniques, and stats that track your progress.',
    href: '/apps/sudoku-xl/',
  },
];
---

<section
  class="phone-scroll"
  data-phone-scroll
  data-screens={JSON.stringify(panels.map((p) => p.screen))}
  data-contact-email={SUPPORT_EMAIL}
>
  <!-- Sticky WebGL stage: the phone lives here and stays put while panels scroll -->
  <div class="phone-stage">
    <canvas class="phone-canvas" data-phone-canvas aria-hidden="true"></canvas>
    <!-- Fallback shown until WebGL takes over (and for reduced-motion / no-JS) -->
    <img
      class="phone-fallback"
      data-phone-fallback
      src="/images/three/screen-company.jpg"
      alt=""
      width="720"
      height="1564"
    />
    <p class="scroll-hint" data-scroll-hint aria-hidden="true">
      <span>Scroll to continue</span>
    </p>
    <!-- Hero CTAs sitting on the phone screen; fade out once you scroll. -->
    <div class="phone-screen-cta" data-hero-cta>
      <a class="btn btn--gradient" href="/apps/">Explore the apps</a>
      <!-- Falls back to the /work/ page without JS; JS intercepts to open the
           on-screen contact form and zoom the phone in. -->
      <a class="btn btn--ghost" href="/work/" data-open-contact>Work with us</a>
    </div>

    <!-- Contact form that appears "on the phone screen" when Work with us is
         clicked. Hidden until then; submits via a prefilled mailto. -->
    <div class="contact-overlay" data-contact hidden>
      <div
        class="contact-card"
        role="dialog"
        aria-modal="true"
        aria-labelledby="contact-title"
        data-contact-card
      >
        <button class="contact-close" type="button" data-contact-close aria-label="Close contact form">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" /></svg>
        </button>

        <form class="contact-form" data-contact-form>
          <p class="contact-eyebrow">Work with us</p>
          <h2 class="contact-heading" id="contact-title">Start a project</h2>
          <p class="contact-sub">Tell us what you have in mind — we reply within two business days.</p>

          <label class="contact-field">
            <span>Your name</span>
            <input type="text" name="name" autocomplete="name" required />
          </label>
          <label class="contact-field">
            <span>Email</span>
            <input type="email" name="email" autocomplete="email" required />
          </label>
          <label class="contact-field">
            <span>What can we build?</span>
            <select name="type">
              <option>An iPhone app</option>
              <option>A website</option>
              <option>App &amp; website</option>
              <option>Not sure yet</option>
            </select>
          </label>
          <label class="contact-field">
            <span>Your idea</span>
            <textarea name="message" rows="3" required></textarea>
          </label>

          <button class="btn btn--gradient contact-submit" type="submit">Send message</button>
        </form>

        <div class="contact-done" data-contact-done hidden>
          <svg class="contact-done-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
          <h2 class="contact-heading">Opening your email…</h2>
          <p class="contact-sub">Your email app should open with the message ready. Just hit send — or write us anytime at support@amsterdamfuturelabs.com.</p>
          <button class="btn btn--ghost contact-close-2" type="button" data-contact-close>Close</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Text panels: one per face. Real, crawlable content + the scroll length. -->
  <div class="phone-panels">
    {panels.map((p, i) => (
      <article class="phone-panel" data-panel={i}>
        <div class="phone-panel-inner container">
          <p class="phone-eyebrow">{p.eyebrow}</p>
          <h2 class="phone-title">{p.title}</h2>
          <p class="phone-body">{p.body}</p>
          {p.href && (
            <a class="phone-link" href={p.href}>
              Explore {p.eyebrow}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </a>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .phone-scroll {
    position: relative;
    background: #0a0b0f;
    color: var(--text-light);
  }

  .phone-stage {
    position: sticky;
    top: 0;
    height: 100svh;
    z-index: 0;
    overflow: hidden;
  }

  .phone-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Fallback image, centered like the phone would be. JS hides it on init. */
  .phone-fallback {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 72%;
    width: auto;
    border-radius: 2rem;
    box-shadow: 0 3rem 6rem rgba(0, 0, 0, 0.6);
  }

  .scroll-hint {
    position: absolute;
    left: 50%;
    bottom: 2rem;
    transform: translateX(-50%);
    margin: 0;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--text-light-secondary);
    transition: opacity 0.4s var(--ease-out);
  }

  .scroll-hint span {
    display: inline-block;
    animation: hint-bob 1.8s ease-in-out infinite;
  }

  .scroll-hint.is-hidden {
    opacity: 0;
  }

  @keyframes hint-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  /* Hero CTAs positioned over the phone's screen; fade out on scroll. */
  .phone-screen-cta {
    position: absolute;
    left: 50%;
    top: 63%;
    transform: translate(-50%, -50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    width: min(15rem, 58vw);
    transition:
      opacity 0.4s var(--ease-out),
      transform 0.4s var(--ease-out);
  }

  .phone-screen-cta .btn {
    width: 100%;
    box-shadow: 0 1rem 2.5rem rgba(0, 0, 0, 0.45);
  }

  .phone-screen-cta.is-hidden {
    opacity: 0;
    transform: translate(-50%, -42%);
    pointer-events: none;
  }

  /* ---------- On-screen contact form ---------- */
  /* Sits over the phone; scales/fades in as the 3D phone zooms toward you. */
  .contact-overlay {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: grid;
    place-items: center;
    padding: 1.5rem;
  }

  .contact-overlay[hidden] {
    display: none;
  }

  .contact-card {
    position: relative;
    width: min(20rem, 82vw);
    max-height: 82svh;
    overflow-y: auto;
    padding: 1.6rem 1.4rem;
    border-radius: 1.75rem;
    background: rgba(16, 18, 26, 0.82);
    backdrop-filter: blur(18px) saturate(1.3);
    -webkit-backdrop-filter: blur(18px) saturate(1.3);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 2rem 5rem rgba(0, 0, 0, 0.6);
    color: var(--text-light);
    /* Enter animation: scale up with the zoom. */
    opacity: 0;
    transform: scale(0.86) translateY(10px);
    transition:
      opacity 0.45s var(--ease-out),
      transform 0.55s var(--ease-out);
  }

  .contact-overlay.is-open .contact-card {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  .contact-close {
    position: absolute;
    top: 0.7rem;
    right: 0.7rem;
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: var(--text-light);
    cursor: pointer;
    transition: background 0.2s var(--ease-out);
  }

  .contact-close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .contact-close svg {
    width: 1rem;
    height: 1rem;
  }

  .contact-eyebrow {
    margin: 0 0 0.3rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brand-tint);
  }

  .contact-heading {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 720;
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
  }

  .contact-sub {
    margin: 0.5rem 0 1.1rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-light-secondary);
  }

  .contact-field {
    display: block;
    margin-bottom: 0.85rem;
  }

  .contact-field span {
    display: block;
    margin-bottom: 0.3rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-light-secondary);
  }

  .contact-field input,
  .contact-field select,
  .contact-field textarea {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border-radius: 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-light);
    font: inherit;
    font-size: 0.9rem;
    transition:
      border-color 0.2s var(--ease-out),
      box-shadow 0.2s var(--ease-out);
  }

  .contact-field textarea {
    resize: vertical;
    min-height: 3.5rem;
  }

  .contact-field input:focus,
  .contact-field select:focus,
  .contact-field textarea:focus {
    outline: none;
    border-color: var(--brand-tint);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.28);
  }

  .contact-field select option {
    color: #111;
  }

  .contact-submit {
    width: 100%;
    margin-top: 0.3rem;
  }

  /* Success state after the mailto fires. */
  .contact-done {
    text-align: center;
    padding: 1rem 0.4rem 0.4rem;
  }

  .contact-done[hidden] {
    display: none;
  }

  .contact-done-icon {
    width: 2.6rem;
    height: 2.6rem;
    margin: 0 auto 0.8rem;
    padding: 0.5rem;
    border-radius: 50%;
    color: #fff;
    background: var(--gradient-brand);
  }

  .contact-close-2 {
    margin-top: 1.2rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-card {
      transition: opacity 0.3s ease;
      transform: none;
    }
    .contact-overlay.is-open .contact-card {
      transform: none;
    }
  }

  /* Panels overlay the sticky stage. Pull up by one viewport so the first
     panel sits on top of the phone rather than below it. */
  .phone-panels {
    position: relative;
    z-index: 1;
    margin-top: -100svh;
    pointer-events: none;
  }

  .phone-panel {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-block: clamp(3rem, 10vh, 8rem);
  }

  /* Hero: copy sits high so the on-screen CTAs own the lower half. */
  .phone-panel[data-panel='0'] {
    align-items: flex-start;
  }

  .phone-panel-inner {
    position: relative;
    max-width: 34rem;
    /* Centered column: copy overlaps the phone (in front of it). */
    margin-inline: auto;
    pointer-events: auto;
    /* Legible + punchy over the bright screen it overlaps. */
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.9), 0 6px 44px rgba(0, 0, 0, 0.55);
  }

  /* Soft dark scrim behind the copy so it reads over bright app screens.
     Radial + fading, so it feels like a gentle shadow, not a hard box. */
  .phone-panel-inner::before {
    content: '';
    position: absolute;
    inset: -3rem -4rem;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(
      72% 68% at 42% 50%,
      rgba(5, 6, 9, 0.82),
      rgba(5, 6, 9, 0.45) 50%,
      transparent 78%
    );
  }

  .phone-eyebrow {
    margin: 0 0 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brand-tint);
  }

  .phone-title {
    margin: 0;
    font-size: clamp(2.2rem, 5.6vw, 3.9rem);
    line-height: 1.02;
    letter-spacing: var(--tracking-tight);
    font-weight: 750;
  }

  .phone-body {
    margin: 1.2rem 0 0;
    max-width: 42ch;
    color: var(--text-light-secondary);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .phone-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.6rem;
    font-weight: 600;
    color: var(--text-light);
    text-decoration: none;
  }

  .phone-link svg {
    width: 1.1rem;
    height: 1.1rem;
    transition: transform 0.25s var(--ease-out);
  }

  .phone-link:hover svg {
    transform: translateX(4px);
  }

  .phone-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.8rem;
  }

  @media (min-width: 900px) {
    .phone-panel-inner {
      max-width: 40rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-hint span {
      animation: none;
    }
  }
</style>

<script>
  import * as THREE from 'three';
  import { RoomEnvironment } from 'three/examples/jsm/environments/RoomEnvironment.js';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

  const section = document.querySelector<HTMLElement>('[data-phone-scroll]');
  const canvas = document.querySelector<HTMLCanvasElement>('[data-phone-canvas]');
  const fallback = document.querySelector<HTMLElement>('[data-phone-fallback]');
  const hint = document.querySelector<HTMLElement>('[data-scroll-hint]');
  const heroCta = document.querySelector<HTMLElement>('[data-hero-cta]');

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (section && canvas && !reduceMotion) {
    const screens: string[] = JSON.parse(section.dataset.screens || '[]');
    const faces = screens.length;

    // ---------- Renderer / scene / camera ----------
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 0.98;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(32, 1, 0.1, 100);
    camera.position.set(0, 0, 9);

    // Image-based lighting: a soft room env drives realistic reflections on
    // the titanium frame and glass — the difference between a plastic toy and
    // a phone render.
    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

    // ---------- Accent lighting (on top of the IBL fill) ----------
    const key = new THREE.DirectionalLight(0xffffff, 1.6);
    key.position.set(4, 6, 8);
    scene.add(key);
    const rimA = new THREE.DirectionalLight(0x6366f1, 1.6);
    rimA.position.set(-6, 2, 3);
    scene.add(rimA);
    const rimB = new THREE.DirectionalLight(0x22d3ee, 1.3);
    rimB.position.set(5, -4, -4);
    scene.add(rimB);

    // ---------- Phone: real iPhone 17 Pro Max model (GLB) ----------
    const phone = new THREE.Group();
    scene.add(phone);

    // App-screen textures shown on the OLED. flipY=false to match glTF UVs.
    const loader = new THREE.TextureLoader();
    const textures = screens.map((src) => {
      const t = loader.load(src);
      t.colorSpace = THREE.SRGBColorSpace;
      t.flipY = false;
      // The OLED UVs read mirrored for our textures — flip horizontally.
      t.wrapS = THREE.RepeatWrapping;
      t.repeat.x = -1;
      t.offset.x = 1;
      t.anisotropy = renderer.capabilities.getMaxAnisotropy();
      return t;
    });

    // The screen ("OLED") material — resolved once the model has loaded.
    let oledMat: THREE.MeshStandardMaterial | null = null;
    let currentFace = -1;

    const gltfLoader = new GLTFLoader();
    gltfLoader.load(
      '/models/iphone-17-pro-max.glb',
      (gltf) => {
      const model = gltf.scene;

      // Light the OLED like a display and prime it with the first app.
      model.traverse((o) => {
        const mesh = o as THREE.Mesh;
        if (!mesh.isMesh) return;
        const mat = mesh.material as THREE.MeshStandardMaterial;
        if (mat && mat.name === 'OLED') {
          oledMat = mat;
          mat.map = textures[0];
          mat.emissive = new THREE.Color(0xffffff);
          mat.emissiveMap = textures[0];
          mat.emissiveIntensity = 1;
          mat.toneMapped = false;
          mat.needsUpdate = true;
        }
      });

      // The model's screen faces -Z by default; turn it to face the camera at
      // rotation 0 so panels show the display, not the back.
      model.rotation.y = Math.PI;

      // Normalize: scale to a consistent height, then recentre at the origin
      // so the scroll rotation spins around the phone's middle.
      const pre = new THREE.Box3().setFromObject(model);
      const size = pre.getSize(new THREE.Vector3());
      model.scale.setScalar(3.9 / size.y);
      const post = new THREE.Box3().setFromObject(model);
      model.position.sub(post.getCenter(new THREE.Vector3()));

      phone.add(model);
      currentFace = -1; // force a screen refresh on the next frame
      fallback?.style.setProperty('opacity', '0');
      window.dispatchEvent(new Event('phone:ready'));
      },
      (e) => {
        // Feed download progress to the preloader bar.
        if (e.total) {
          window.dispatchEvent(new CustomEvent('phone:progress', { detail: e.loaded / e.total }));
        }
      },
      () => {
        // On error, keep the fallback and release the loader.
        window.dispatchEvent(new Event('phone:ready'));
      }
    );

    // ---------- Resize ----------
    function resize() {
      const w = canvas!.clientWidth;
      const h = canvas!.clientHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      // Frame the phone a touch smaller on narrow screens.
      baseZ = w / h < 0.7 ? 11.5 : 9;
    }
    resize();
    window.addEventListener('resize', resize);

    // Fade the fallback out smoothly; it's hidden once the model loads.
    fallback?.style.setProperty('transition', 'opacity 0.5s ease');

    // ---------- Scroll-driven animation ----------
    // `pp` is a floating panel index: 0 when panel 0 is centered, 1 for panel
    // 1, etc. Derived straight from the section's viewport offset, so the
    // phone faces forward with the matching app exactly when a panel centers.
    const N = faces;
    let targetPP = 0;
    let smoothPP = 0;

    // Camera distance + contact-form zoom. `baseZ` is the resting distance
    // (set in resize); `contactZoom` is the 0→1 target the render loop eases
    // toward, pulling the camera closer when the contact form is open.
    let baseZ = 9;
    let contactZoom = 0;
    let zoomEase = 0;
    window.addEventListener('contact:open', () => { contactZoom = 1; });
    window.addEventListener('contact:close', () => { contactZoom = 0; });

    function computePP() {
      const rect = section!.getBoundingClientRect();
      const pp = -rect.top / window.innerHeight;
      return Math.min(Math.max(pp, 0), N - 1);
    }

    function onScroll() {
      targetPP = computePP();
      if (hint) hint.classList.toggle('is-hidden', targetPP > 0.06);
      if (heroCta) heroCta.classList.toggle('is-hidden', targetPP > 0.03);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
    smoothPP = targetPP;

    function render() {
      // Inertia: ease toward the target for weight / momentum.
      smoothPP += (targetPP - smoothPP) * 0.09;
      const pp = smoothPP;
      const norm = N > 1 ? pp / (N - 1) : 0; // 0..1 across the whole scroll

      // One full turn between adjacent panels → faces forward at each panel.
      phone.rotation.y = pp * Math.PI * 2;
      // Gentle secondary motion for depth.
      phone.rotation.x = Math.sin(pp * Math.PI) * 0.1;
      phone.rotation.z = Math.sin(pp * Math.PI * 0.5) * 0.05;
      // Translate down + drift as you scroll through the section.
      phone.position.y = 0.4 - norm * 1.0;
      phone.position.x = Math.sin(norm * Math.PI) * 0.45;

      // Ease the camera toward the phone when the contact form opens (zoom in).
      zoomEase += (contactZoom - zoomEase) * 0.08;
      camera.position.z = baseZ * (1 - zoomEase * 0.34);

      // Swap the screen texture at the nearest panel — this lands on the
      // half-step where the phone faces away, so the change stays hidden.
      const face = Math.round(pp);
      if (face !== currentFace && textures[face]) {
        currentFace = face;
        if (oledMat) {
          oledMat.map = textures[face];
          oledMat.emissiveMap = textures[face];
          oledMat.needsUpdate = true;
        }
      }

      renderer.render(scene, camera);
      requestAnimationFrame(render);
    }
    render();
  } else {
    // No WebGL / reduced motion: no model to wait for — release the loader.
    if (document.readyState === 'complete') {
      window.dispatchEvent(new Event('phone:ready'));
    } else {
      window.addEventListener('load', () => window.dispatchEvent(new Event('phone:ready')));
    }
  }
</script>

<script>
  // ---------- On-screen contact form ----------
  // Runs regardless of WebGL support: intercepts "Work with us", reveals the
  // form over the phone (dispatching contact:open so the 3D scene zooms in),
  // and submits by opening the visitor's mail app with a prefilled message.
  const scroll = document.querySelector<HTMLElement>('[data-phone-scroll]');
  const overlay = document.querySelector<HTMLElement>('[data-contact]');
  const openers = document.querySelectorAll<HTMLAnchorElement>('[data-open-contact]');
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  const done = document.querySelector<HTMLElement>('[data-contact-done]');
  const closers = document.querySelectorAll<HTMLElement>('[data-contact-close]');

  if (scroll && overlay && form && done && openers.length) {
    const email = scroll.dataset.contactEmail || 'support@amsterdamfuturelabs.com';
    let lastFocus: HTMLElement | null = null;
    let isOpen = false;

    function openContact() {
      if (isOpen) return;
      isOpen = true;
      lastFocus = document.activeElement as HTMLElement;

      // Bring the phone to its forward-facing, centered pose and hold it there
      // so the form sits squarely on the screen while open.
      window.scrollTo({ top: 0, behavior: 'auto' });
      document.body.style.overflow = 'hidden';

      overlay!.hidden = false;
      // Reset to the form view in case it was previously submitted.
      form!.hidden = false;
      done!.hidden = true;
      // Next frame so the transition runs from the hidden state.
      requestAnimationFrame(() => overlay!.classList.add('is-open'));
      window.dispatchEvent(new Event('contact:open'));

      const first = form!.querySelector<HTMLElement>('input, textarea, select');
      first?.focus();
    }

    function closeContact() {
      if (!isOpen) return;
      isOpen = false;
      overlay!.classList.remove('is-open');
      document.body.style.overflow = '';
      window.dispatchEvent(new Event('contact:close'));

      // Hide after the fade-out so it can't be tabbed to.
      window.setTimeout(() => { overlay!.hidden = true; }, 500);
      lastFocus?.focus();
    }

    openers.forEach((a) => a.addEventListener('click', (e) => {
      e.preventDefault();
      openContact();
    }));

    closers.forEach((b) => b.addEventListener('click', closeContact));

    // Escape closes; click on the backdrop (outside the card) closes too.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeContact();
    });
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeContact();
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form!);
      const name = String(data.get('name') || '').trim();
      const from = String(data.get('email') || '').trim();
      const type = String(data.get('type') || '').trim();
      const message = String(data.get('message') || '').trim();

      const subject = `Project inquiry — ${type}`;
      const body =
        `Name: ${name}\n` +
        `Email: ${from}\n` +
        `Project: ${type}\n\n` +
        `${message}\n`;
      const href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

      // Swap to the confirmation view, then open the mail app.
      form!.hidden = true;
      done!.hidden = false;
      window.location.href = href;
    });
  }
</script>
