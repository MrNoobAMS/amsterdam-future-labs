---
import type { AppMeta } from '../data/apps';
import CTAButton from './CTAButton.astro';

interface Props {
  app: AppMeta;
  /** Compact cards (home grid) hide the secondary CTA. */
  compact?: boolean;
}

const { app, compact = false } = Astro.props;
const available = app.status === 'available';
const framed = app.framedScreenshots ?? false;
---

<article class="app-card card" style={`--app-accent:${app.accent}; --app-accent-soft:${app.accentSoft}`}>
  <a href={`/apps/${app.slug}/`} class:list={['app-card-media', { 'app-card-media--framed': framed }]} aria-hidden="true" tabindex="-1">
    <img
      src={app.screenshots[0].src}
      alt=""
      width="330"
      height="717"
      loading="lazy"
      decoding="async"
    />
  </a>

  <div class="app-card-body">
    <div class="app-card-top">
      <img class="app-card-icon" src={app.icon} alt="" width="56" height="56" loading="lazy" />
      <span class="app-card-category">{app.category}</span>
    </div>

    <h3 class="app-card-name">
      <a href={`/apps/${app.slug}/`}>{app.name}</a>
    </h3>
    <p class="app-card-desc">{app.shortDescription}</p>

    <div class="app-card-actions">
      <CTAButton href={`/apps/${app.slug}/`} variant="primary" arrow>View app</CTAButton>
      {!compact && (
        available ? (
          <CTAButton href={app.appStoreUrl ?? '#'} variant="ghost" appStore>Download</CTAButton>
        ) : (
          <span class="coming-soon-pill">Coming soon</span>
        )
      )}
    </div>
  </div>
</article>

<style>
  .app-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: 100%;
  }

  .app-card:hover {
    transform: translateY(-6px);
    box-shadow:
      0 24px 48px -20px rgba(14, 15, 20, 0.25),
      0 0 0 1px var(--app-accent-soft);
    border-color: transparent;
  }

  .app-card-media {
    display: grid;
    place-items: center;
    padding: 2.2rem 2.2rem 0;
    background:
      radial-gradient(120% 90% at 50% 110%, var(--app-accent-soft), transparent 70%),
      linear-gradient(180deg, rgba(14, 15, 20, 0.035), transparent);
    overflow: hidden;
  }

  .app-card-media img {
    width: min(58%, 180px);
    height: auto;
    aspect-ratio: 1320 / 2868;
    object-fit: cover;
    object-position: top;
    border-radius: 1.2rem 1.2rem 0 0;
    box-shadow:
      0 0 0 5px #17181f,
      0 18px 40px -14px rgba(14, 15, 20, 0.5);
    transform: translateY(10px);
    transition: transform 0.45s var(--ease-out);
  }

  .app-card:hover .app-card-media img {
    transform: translateY(2px) scale(1.02);
  }

  /* Pre-branded App Store images already carry their own background and
     rounding — drop the dark "phone edge" ring (jarring on light frames). */
  .app-card-media--framed img {
    box-shadow: 0 18px 40px -16px rgba(14, 15, 20, 0.4);
  }

  .app-card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.7rem;
    padding: 1.5rem 1.6rem 1.6rem;
  }

  .app-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .app-card-icon {
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 0.8rem;
    box-shadow: 0 4px 12px -4px rgba(14, 15, 20, 0.35);
  }

  .app-card-category {
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--app-accent);
    background: var(--app-accent-soft);
    padding: 0.32rem 0.7rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .app-card-name {
    font-size: 1.35rem;
  }

  .app-card-name a {
    text-decoration: none;
    color: inherit;
  }

  /* Make the whole card clickable through the title link */
  .app-card-name a::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .app-card {
    position: relative;
  }

  .app-card-desc {
    font-size: 0.95rem;
    color: var(--text-dark-secondary);
    flex: 1;
  }

  :global(.section--dark) .app-card-desc {
    color: var(--text-light-secondary);
  }

  .app-card-actions {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7rem;
    margin-top: 0.6rem;
  }

  .coming-soon-pill {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-dark-secondary);
    border: 1px dashed var(--line-dark);
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
  }

  :global(.section--dark) .coming-soon-pill {
    color: var(--text-light-secondary);
    border-color: var(--line-light);
  }
</style>
