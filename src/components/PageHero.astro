---
import AnimatedSection from './AnimatedSection.astro';
import SplitText from './SplitText.astro';

/**
 * Dark hero used on sub-pages so the fixed header always sits on a dark
 * surface. Accepts an optional accent for app-tinted glows.
 */
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
  accent?: string;
}

const { eyebrow, title, lead, accent } = Astro.props;
---

<section class="page-hero section--dark" style={accent ? `--hero-accent:${accent}` : undefined}>
  <div class="hero-glow" data-parallax="0.18" aria-hidden="true"></div>
  <div class="container">
    <AnimatedSection>
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="display" aria-label={title}><SplitText text={title} /></h1>
      {lead && <p class="lead page-hero-lead">{lead}</p>}
      <slot />
    </AnimatedSection>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(8.5rem, 18vw, 12rem) 0 clamp(4rem, 8vw, 6rem);
  }

  .hero-glow {
    position: absolute;
    top: -30%;
    right: -15%;
    width: 60rem;
    height: 60rem;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--hero-accent, var(--brand-b)) 22%, transparent),
      transparent 65%
    );
    pointer-events: none;
  }

  .page-hero .display {
    max-width: 18ch;
  }

  .page-hero-lead {
    margin-top: 1.4rem;
    max-width: 56ch;
  }
</style>
