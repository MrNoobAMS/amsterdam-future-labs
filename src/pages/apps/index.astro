---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import AnimatedSection from '../../components/AnimatedSection.astro';
import AppCard from '../../components/AppCard.astro';
import { apps } from '../../data/apps';
---

<BaseLayout
  title="Apps — Amsterdam Future Labs"
  description="Explore all Amsterdam Future Labs apps for iPhone: Meal Planner, BreathWell, Kamado Companion, Airfryer Companion and Sudoku XL. Private by design and offline first."
>
  <PageHero
    eyebrow="Portfolio"
    title="The apps"
    lead="Five iPhone apps, one philosophy: beautifully crafted, private by design and fully functional offline."
  />

  <section class="section">
    <div class="container">
      <div class="apps-grid">
        {apps.map((app, i) => (
          <AnimatedSection delay={(i % 2) * 0.08}>
            <AppCard app={app} />
          </AnimatedSection>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .apps-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  .apps-grid > :global(*) {
    height: 100%;
  }

  @media (min-width: 700px) {
    .apps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
