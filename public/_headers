# Cloudflare Pages cache policy.
# Hashed, content-addressed assets never change — cache them forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted font is stable — cache aggressively.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Images can change between releases — cache a week, revalidate after.
/images/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/favicon.svg
  Cache-Control: public, max-age=604800

# HTML: always revalidate so content updates ship immediately.
/*
  Cache-Control: public, max-age=0, must-revalidate
